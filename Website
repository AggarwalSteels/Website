/* ── Pages ── */
.page { display: none; min-height: 100vh; }
.page.active { display: block; }

/* ═══════════════════════════════════════════
   HERO — Full-bleed immersive dark
   ═══════════════════════════════════════════ */
#hero {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,113,227,.15) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 20%, rgba(90,200,250,.08) 0%, transparent 50%),
    linear-gradient(180deg, #000 0%, #0a0a1a 100%);
  display: flex; align-items: center; padding-top: 52px;
  position: relative; overflow: hidden;
}
#hero::before {
  content: ''; position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='50' cy='50' r='.5' fill='rgba(255,255,255,.03)'/%3E%3C/svg%3E") repeat;
  pointer-events: none;
}
.hero-content { max-width: 740px; position: relative; z-index: 1; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(0,113,227,.12); border: 1px solid rgba(0,113,227,.25);
  padding: 7px 18px; border-radius: 980px;
  color: var(--blue-light); font-size: .78rem; font-weight: 500;
  letter-spacing: .06em; text-transform: uppercase;
  margin-bottom: 28px;
  backdrop-filter: blur(12px);
}
.hero-eyebrow .dot { width: 6px; height: 6px; background: var(--blue-light); border-radius: 50%; animation: pulse-dot 2s infinite; }
@keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.7)} }
.hero-title { color: var(--white); margin-bottom: 24px; }
.hero-title .accent { background: linear-gradient(135deg, var(--blue-light), var(--teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-desc { color: rgba(255,255,255,.6); font-size: 1.15rem; margin-bottom: 40px; max-width: 520px; line-height: 1.7; }
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 64px; }
.hero-stats { display: flex; gap: 48px; flex-wrap: wrap; }
.hero-stat { color: var(--white); text-align: center; }
.hero-stat .stat-num { font-family: var(--font-display); font-size: 2.4rem; font-weight: 800; background: linear-gradient(135deg, var(--white), var(--blue-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1; letter-spacing: -.03em; }
.hero-stat .stat-label { font-size: .75rem; color: var(--text-light); margin-top: 6px; letter-spacing: .04em; text-transform: uppercase; }

/* ── Price Ticker ── */
#price-ticker {
  background: rgba(0,0,0,.6); backdrop-filter: blur(20px);
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid rgba(0,113,227,.3); padding: 0;
}
.ticker-wrap { display: flex; align-items: center; height: 40px; overflow: hidden; }
.ticker-label {
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  color: var(--white); padding: 0 18px; height: 100%;
  display: flex; align-items: center;
  font-size: .72rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; white-space: nowrap; flex-shrink: 0;
}
.ticker-scroll { flex: 1; overflow: hidden; position: relative; }
.ticker-inner { display: flex; gap: 48px; animation: ticker-scroll 40s linear infinite; width: max-content; }
.ticker-inner:hover { animation-play-state: paused; }
@keyframes ticker-scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.ticker-item { display: flex; align-items: center; gap: 10px; color: var(--white); font-size: .8rem; white-space: nowrap; }
.ticker-item .ti-name { color: var(--text-light); font-weight: 500; font-size: .72rem; text-transform: uppercase; letter-spacing: .03em; }
.ticker-item .ti-price { color: var(--white); font-weight: 700; letter-spacing: -.01em; }
.ticker-item .ti-change { font-size: .68rem; font-weight: 600; }
.ti-up { color: var(--success); }
.ti-down { color: var(--error); }

/* ── Categories ── */
#categories { background: var(--surface); }
.categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px,1fr)); gap: 20px; margin-top: 56px; }
.cat-card {
  background: var(--white);
  border-radius: var(--radius-lg); border: 1px solid var(--border);
  padding: 32px 18px; text-align: center;
  cursor: pointer; transition: var(--transition);
  box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
}
.cat-card::after { content:''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--blue), var(--blue-light)); transform: scaleX(0); transition: transform .4s ease; }
.cat-card:hover::after { transform: scaleX(1); }
.cat-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-6px); }
.cat-img {
  width: 100%; height: 120px; margin-bottom: 14px;
  border-radius: 12px; overflow: hidden;
}
.cat-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: var(--transition);
}
.cat-card:hover .cat-img img { transform: scale(1.08); }
.cat-name { font-size: .92rem; font-weight: 700; color: var(--text); margin-bottom: 4px; letter-spacing: -.01em; }
.cat-sub { font-size: .72rem; color: var(--text-light); }
.cat-arrow { margin-top: 14px; display: inline-flex; align-items: center; gap: 4px; color: var(--blue); font-size: .75rem; font-weight: 600; opacity: 0; transform: translateY(4px); transition: var(--transition); }
.cat-card:hover .cat-arrow { opacity: 1; transform: translateY(0); }

/* ── Why Us ── */
#why-us { background: var(--bg-dark); overflow: hidden; position: relative; }
#why-us::before { content:''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 30% 50%, rgba(0,113,227,.1) 0%, transparent 60%); }
#why-us .section-title { color: var(--white); }
#why-us .section-tag { color: var(--blue-light); }
#why-us .section-tag::before { background: var(--blue-light); }
#why-us .section-title span { background: linear-gradient(135deg, var(--blue-light), var(--teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
#why-us .section-subtitle { color: var(--text-light); }
.why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 20px; margin-top: 56px; }
.why-card {
  background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--radius-lg); padding: 32px;
  transition: var(--transition);
  backdrop-filter: blur(12px);
}
.why-card:hover { background: rgba(255,255,255,.08); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.3); border-color: rgba(0,113,227,.3); }
.why-icon { font-size: 2rem; margin-bottom: 16px; }
.why-title { color: var(--white); font-size: 1rem; font-weight: 700; margin-bottom: 8px; letter-spacing: -.01em; }
.why-desc { color: var(--text-light); font-size: .875rem; line-height: 1.7; }

/* ── How to Order ── */
#how-to { background: var(--white); }
.steps-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; margin-top: 56px; position: relative; }
.steps-grid::before { content:''; position: absolute; top: 36px; left: calc(16.66% + 24px); right: calc(16.66% + 24px); height: 2px; background: linear-gradient(90deg, var(--blue), var(--blue-light)); border-radius: 2px; opacity: .4; }
.step-item { text-align: center; padding: 0 24px; }
.step-num {
  width: 56px; height: 56px; margin: 0 auto 20px;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem; font-weight: 900; color: var(--white);
  position: relative; z-index: 1; box-shadow: var(--shadow-blue);
}
.step-num::after { content:''; position: absolute; inset: -4px; border-radius: 50%; border: 2px solid rgba(0,113,227,.25); }
.step-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.step-desc { font-size: .875rem; color: var(--text-mid); line-height: 1.7; }

/* ── Trust Strip ── */
#trust-strip { background: var(--surface); padding: 40px 0; border-top: 1px solid var(--surface-2); border-bottom: 1px solid var(--surface-2); }
.trust-inner { display: flex; align-items: center; justify-content: space-around; flex-wrap: wrap; gap: 32px; }
.trust-item { display: flex; align-items: center; gap: 14px; }
.trust-icon { font-size: 2rem; }
.trust-text .t-num { font-family: var(--font-display); font-size: 1.6rem; font-weight: 800; color: var(--text); line-height: 1; letter-spacing: -.02em; }
.trust-text .t-label { font-size: .75rem; color: var(--text-light); text-transform: uppercase; letter-spacing: .04em; }

/* ═══════════════════════════════════════════
   PRODUCT PAGE
   ═══════════════════════════════════════════ */
#page-product { background: var(--surface); padding-top: 72px; padding-bottom: 60px; min-height: 100vh; }
.product-breadcrumb { display: flex; align-items: center; gap: 8px; font-size: .8rem; color: var(--text-light); margin-bottom: 28px; padding-top: 20px; }
.product-breadcrumb a { color: var(--blue); font-weight: 500; }
.product-layout { display: grid; grid-template-columns: 1fr 440px; gap: 32px; align-items: start; }
.product-header { margin-bottom: 24px; }
.product-category-tag { display: inline-block; padding: 5px 16px; background: rgba(0,113,227,.08); color: var(--blue); border-radius: 980px; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 14px; }
.product-title { color: var(--text); margin-bottom: 8px; }
.product-standard { color: var(--text-light); font-size: .85rem; }
.product-image-card {
  border-radius: var(--radius-lg); overflow: hidden;
  border: 1px solid var(--border); box-shadow: var(--shadow);
}
.product-image-card img {
  width: 100%; height: 280px; object-fit: cover;
  display: block;
}
.product-desc { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); padding: 24px; margin-bottom: 24px; }

/* ── Maker Logos ── */
.maker-strip {
  display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
}
.maker-logo-item {
  display: flex; align-items: center; justify-content: center;
  width: 100px; height: 48px; padding: 8px;
  background: var(--surface); border-radius: var(--radius-sm);
  border: 1px solid var(--border); transition: var(--transition);
}
.maker-logo-item:hover { border-color: var(--blue); box-shadow: var(--shadow-sm); }
.maker-logo-item img {
  max-width: 80px; max-height: 32px; object-fit: contain;
  filter: grayscale(.3); transition: var(--transition);
}
.maker-logo-item:hover img { filter: grayscale(0); }
.maker-fallback {
  font-size: .7rem; font-weight: 700; color: var(--text-mid);
  text-align: center; align-items: center; justify-content: center;
}
.product-desc h4 { color: var(--text); margin-bottom: 12px; font-size: .95rem; }
.product-desc ul { padding-left: 4px; }
.product-desc ul li { position: relative; padding-left: 22px; margin-bottom: 7px; font-size: .875rem; color: var(--text-mid); }
.product-desc ul li::before { content: '✓'; position: absolute; left: 0; color: var(--blue); font-weight: 700; }
.specs-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
.specs-table tr { border-bottom: 1px solid var(--surface-2); }
.specs-table tr:last-child { border-bottom: none; }
.specs-table td { padding: 10px 16px; font-size: .85rem; }
.specs-table td:first-child { color: var(--text-light); width: 45%; }
.specs-table td:last-child { color: var(--text); font-weight: 500; }
.applications-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
.app-chip { padding: 5px 14px; background: var(--surface); border-radius: 980px; font-size: .78rem; color: var(--text-mid); border: 1px solid var(--surface-2); transition: var(--transition-fast); }
.app-chip:hover { border-color: var(--blue); color: var(--blue); }

/* ── Configurator ── */
.configurator { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-lg); position: sticky; top: 72px; }
.configurator-header {
  background: linear-gradient(135deg, #0a0a1a, #111140);
  color: var(--white); padding: 22px 24px;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  display: flex; justify-content: space-between; align-items: center;
}
.configurator-header h3 { font-size: 1rem; color: var(--white); font-weight: 600; }
.price-per-mt { text-align: right; }
.price-per-mt .pmt-label { font-size: .68rem; color: var(--text-light); }
.price-per-mt .pmt-val { font-size: 1.3rem; font-weight: 800; background: linear-gradient(135deg, var(--blue-light), var(--teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.price-per-mt .pmt-upd { font-size: .62rem; color: var(--text-light); }
.configurator-body { padding: 24px; }

/* ── Price Summary ── */
.price-summary {
  background: linear-gradient(135deg, rgba(0,113,227,.04) 0%, rgba(90,200,250,.06) 100%);
  border: 1.5px solid rgba(0,113,227,.2);
  border-radius: var(--radius-sm); padding: 18px;
  margin-top: 4px; margin-bottom: 20px;
}
.price-row { display: flex; justify-content: space-between; font-size: .85rem; padding: 5px 0; color: var(--text-mid); }
.price-row.total { font-size: 1.05rem; font-weight: 700; color: var(--text); border-top: 1px dashed var(--surface-2); padding-top: 12px; margin-top: 8px; }
.price-row.total .val { color: var(--blue); font-size: 1.15rem; }
.gst-note { font-size: .72rem; color: var(--text-light); text-align: right; margin-top: 4px; }

/* ═══════════════════════════════════════════
   CART
   ═══════════════════════════════════════════ */
#page-cart { background: var(--surface); padding-top: 72px; padding-bottom: 60px; min-height: 100vh; }
.cart-layout { display: grid; grid-template-columns: 1fr 360px; gap: 28px; align-items: start; }
.cart-panel { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; }
.cart-panel-header { background: var(--surface); padding: 16px 24px; border-bottom: 1px solid var(--surface-2); display: flex; justify-content: space-between; align-items: center; }
.cart-panel-header h3 { font-size: .9rem; font-weight: 700; color: var(--text); }
.cart-item { display: grid; grid-template-columns: 1fr auto; gap: 12px; padding: 20px 24px; border-bottom: 1px solid var(--surface-2); align-items: center; transition: var(--transition-fast); }
.cart-item:hover { background: var(--surface); }
.ci-meta h4 { font-size: .9rem; color: var(--text); font-weight: 600; margin-bottom: 4px; }
.ci-meta .ci-specs { font-size: .75rem; color: var(--text-light); line-height: 1.6; }
.ci-meta .ci-price-per { font-size: .8rem; color: var(--text-mid); margin-top: 4px; }
.ci-right { text-align: right; }
.ci-total { font-size: 1.05rem; font-weight: 700; color: var(--text); }
.ci-gst { font-size: .72rem; color: var(--text-light); }
.ci-remove { background: none; padding: 4px; color: var(--error); font-size: 1.1rem; margin-top: 6px; opacity: .5; transition: var(--transition-fast); }
.ci-remove:hover { opacity: 1; }
.cart-empty { text-align: center; padding: 72px 24px; color: var(--text-light); display: none; }
.cart-empty.show { display: block; }
.cart-empty .ce-icon { font-size: 3.5rem; margin-bottom: 16px; }
.cart-empty h3 { color: var(--text-mid); font-size: 1.1rem; margin-bottom: 8px; }

/* ── Order Summary ── */
.order-summary { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; position: sticky; top: 72px; }
.os-header { background: linear-gradient(135deg, #0a0a1a, #111140); color: var(--white); padding: 18px 20px; }
.os-header h3 { font-size: .9rem; color: var(--white); }
.os-body { padding: 20px; }
.os-row { display: flex; justify-content: space-between; font-size: .85rem; padding: 7px 0; color: var(--text-mid); }
.os-row.subtotal { font-weight: 600; color: var(--text); border-top: 1px solid var(--surface-2); padding-top: 12px; margin-top: 4px; }
.os-row.grand { font-size: 1.1rem; font-weight: 800; color: var(--text); border-top: 2px solid var(--text); padding-top: 12px; margin-top: 4px; }
.os-row.grand .os-val { color: var(--blue); }
.gst-type-selector { margin-top: 16px; }
.state-hint { font-size: .72rem; color: var(--text-light); margin-top: 6px; }

/* ═══════════════════════════════════════════
   CHECKOUT
   ═══════════════════════════════════════════ */
#page-checkout { background: var(--surface); padding-top: 72px; padding-bottom: 60px; min-height: 100vh; }
.checkout-layout { display: grid; grid-template-columns: 1fr 340px; gap: 28px; align-items: start; }
.checkout-form-card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: 36px; box-shadow: var(--shadow); }
.form-section + .form-section { margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--surface-2); }
.form-section-title { font-size: .7rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--blue); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
.form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.order-confirm { display: none; text-align: center; padding: 56px 24px; }
.order-confirm.show { display: block; }
.order-confirm .oc-icon { font-size: 4.5rem; margin-bottom: 20px; }
.order-confirm h2 { color: var(--text); margin-bottom: 10px; }
.order-confirm .oc-id { font-size: .9rem; color: var(--text-light); margin-bottom: 24px; }
.order-confirm .oc-msg { background: var(--surface); border-radius: var(--radius); padding: 20px; font-size: .9rem; color: var(--text-mid); margin-bottom: 32px; line-height: 1.7; }
.checkout-summary { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; position: sticky; top: 72px; }
.cs-header { background: linear-gradient(135deg, #0a0a1a, #111140); padding: 18px 20px; }
.cs-header h3 { color: var(--white); font-size: .9rem; }
.cs-body { padding: 20px; }
.cs-item { padding: 10px 0; border-bottom: 1px solid var(--surface-2); }
.cs-item:last-child { border-bottom: none; }
.cs-item .cs-name { font-size: .85rem; font-weight: 600; color: var(--text); }
.cs-item .cs-detail { font-size: .72rem; color: var(--text-light); margin-top: 2px; }
.cs-item .cs-price { font-size: .875rem; font-weight: 700; color: var(--text); margin-top: 4px; }
.cs-divider { border: none; border-top: 2px solid var(--surface-2); margin: 12px 0; }
.cs-total-row { display: flex; justify-content: space-between; font-size: .875rem; padding: 4px 0; }
.cs-grand { font-weight: 800; font-size: 1.05rem; color: var(--text); }
.cs-grand .cs-val { color: var(--blue); }

/* ═══════════════════════════════════════════
   ADMIN
   ═══════════════════════════════════════════ */
#page-admin { background: var(--surface); padding-top: 72px; padding-bottom: 60px; min-height: 100vh; }
.admin-login-card { max-width: 420px; margin: 60px auto 0; background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: 44px; box-shadow: var(--shadow-lg); }
.admin-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(0,113,227,.08); color: var(--blue); padding: 6px 16px; border-radius: 980px; font-size: .75rem; font-weight: 700; margin-bottom: 20px; }
.admin-table-wrap { background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); overflow: auto; box-shadow: var(--shadow); }
.admin-table { width: 100%; border-collapse: collapse; min-width: 700px; }
.admin-table th { background: linear-gradient(135deg, #0a0a1a, #111140); color: var(--blue-light); padding: 14px 16px; text-align: left; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
.admin-table td { padding: 14px 16px; border-bottom: 1px solid var(--surface-2); font-size: .875rem; }
.admin-table tr:hover td { background: var(--surface); }
.price-input-cell { display: flex; align-items: center; gap: 8px; }
.price-input-cell input { width: 120px; padding: 8px 12px; border: 1.5px solid var(--surface-2); border-radius: var(--radius-sm); font-size: .875rem; font-weight: 600; }
.price-input-cell input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-glow); }
.save-price-btn { padding: 8px 16px; background: var(--blue); color: var(--white); border-radius: 980px; font-size: .78rem; font-weight: 600; transition: var(--transition-fast); }
.save-price-btn:hover { background: var(--blue-dark); }
.saved-tag { color: var(--success); font-size: .75rem; font-weight: 600; display: none; }
.saved-tag.show { display: inline; }

/* ═══════════════════════════════════════════
   CONTACT & FOOTER
   ═══════════════════════════════════════════ */
#page-contact { background: var(--surface); padding-top: 72px; min-height: 100vh; }
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 48px; }
.contact-item { display: flex; gap: 16px; align-items: flex-start; padding: 24px; background: var(--white); border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 16px; transition: var(--transition); }
.contact-item:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
.ci-icon { width: 48px; height: 48px; background: linear-gradient(135deg, rgba(0,113,227,.08), rgba(90,200,250,.1)); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
.ci-body h4 { font-size: .9rem; font-weight: 600; color: var(--text); margin-bottom: 4px; }
.ci-body p, .ci-body a { font-size: .875rem; color: var(--text-mid); }
.contact-form-card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: 36px; box-shadow: var(--shadow); }

#footer { background: var(--bg-dark); padding: 80px 0 0; }
.footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; }
.footer-brand .fb-tagline { color: var(--text-light); font-size: .875rem; margin-top: 14px; line-height: 1.8; }
.footer-col h4 { color: var(--white); font-size: .82rem; font-weight: 700; margin-bottom: 18px; text-transform: uppercase; letter-spacing: .08em; }
.footer-col ul li { margin-bottom: 10px; }
.footer-col ul li a { color: var(--text-light); font-size: .875rem; transition: var(--transition-fast); }
.footer-col ul li a:hover { color: var(--blue-light); }
.footer-bottom { border-top: 1px solid var(--border-light); padding: 20px 0; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
.footer-bottom p { font-size: .78rem; color: var(--text-light); }
.footer-bottom a { color: var(--blue-light); }

/* ═══════════════════════════════════════════
   FLOATING CART + TOAST
   ═══════════════════════════════════════════ */
#floating-cart-preview {
  position: fixed; right: 24px; bottom: 24px; z-index: 999;
  background: var(--bg-dark-2); color: var(--white);
  border-radius: var(--radius-lg); box-shadow: var(--shadow-xl);
  padding: 16px 22px; display: flex; align-items: center; gap: 14px;
  transform: translateY(20px); opacity: 0; pointer-events: none;
  transition: var(--transition);
  border: 1px solid var(--border-light);
  backdrop-filter: blur(20px);
}
#floating-cart-preview.show { transform: translateY(0); opacity: 1; pointer-events: all; }
.fcp-text { font-size: .875rem; }
.fcp-text .fcp-items { color: var(--text-light); font-size: .75rem; }
.fcp-total { font-weight: 800; font-size: 1rem; color: var(--blue-light); }

#toast-container { position: fixed; top: 64px; right: 20px; z-index: 9000; display: flex; flex-direction: column; gap: 8px; }
.toast {
  padding: 14px 22px; border-radius: var(--radius);
  font-size: .85rem; font-weight: 500; letter-spacing: -.01em;
  box-shadow: var(--shadow-lg); min-width: 300px;
  animation: toast-in .35s cubic-bezier(.25,.1,.25,1);
  backdrop-filter: blur(20px);
}
@keyframes toast-in { from{transform:translateX(100px);opacity:0} to{transform:translateX(0);opacity:1} }
.toast-success { background: rgba(48,209,88,.95); color: white; }
.toast-error { background: rgba(255,69,58,.95); color: white; }
.toast-info { background: rgba(10,10,26,.92); color: white; border: 1px solid var(--border-light); }

/* ═══════════════════════════════════════════
   UTILITIES
   ═══════════════════════════════════════════ */
.text-gold { color: var(--blue); }
.text-navy { color: var(--text); }
.text-white { color: var(--white); }
.text-center { text-align: center; }
.text-right { text-align: right; }
.mt-sm { margin-top: 8px; }
.mt-md { margin-top: 16px; }
.mt-lg { margin-top: 24px; }
.mb-sm { margin-bottom: 8px; }
.mb-md { margin-bottom: 16px; }
.mb-lg { margin-bottom: 24px; }
.divider { border: none; border-top: 1px solid var(--surface-2); margin: 24px 0; }

/* ═══════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════ */
@media (max-width: 1024px) {
  .product-layout { grid-template-columns: 1fr; }
  .configurator { position: static; }
  .cart-layout { grid-template-columns: 1fr; }
  .checkout-layout { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .steps-grid::before { display: none; }
}
@media (max-width: 768px) {
  .section { padding: 64px 0; }
  .nav-links { display: none; }
  .nav-hamburger { display: flex; }
  .nav-inner { padding: 0 16px; }
  .hero-stats { gap: 24px; }
  .grid-2,.grid-3,.grid-4 { grid-template-columns: 1fr; }
  .steps-grid { grid-template-columns: 1fr; gap: 32px; }
  .contact-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; gap: 32px; }
  .footer-bottom { flex-direction: column; text-align: center; }
  .form-grid-2 { grid-template-columns: 1fr; }
  .categories-grid { grid-template-columns: repeat(auto-fill, minmax(130px,1fr)); }
  .hero-stat .stat-num { font-size: 1.8rem; }
}
@media (max-width: 480px) {
  .hero-actions { flex-direction: column; }
  .hero-actions .btn { width: 100%; justify-content: center; }
  .container { padding: 0 16px; }
  .order-confirm { padding: 32px 16px; }
  .otp-input-row { flex-wrap: wrap; }
}

/* Mobile Nav */
.mobile-menu { display: none; position: fixed; inset: 0; z-index: 999; background: rgba(0,0,0,.96); backdrop-filter: blur(24px); flex-direction: column; padding: 80px 24px 32px; }
.mobile-menu.show { display: flex; }
.mobile-menu a { padding: 16px 0; color: var(--white); font-size: 1.1rem; font-weight: 500; border-bottom: 1px solid var(--border-light); display: flex; align-items: center; justify-content: space-between; letter-spacing: -.01em; }
.mobile-menu a:hover { color: var(--blue-light); }
.mobile-close { position: absolute; top: 20px; right: 20px; background: none; color: var(--white); font-size: 1.6rem; padding: 8px; }
